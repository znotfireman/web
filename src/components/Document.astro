---
import "@fontsource-variable/lilex/wght.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

const { pageTitle } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} /><meta name="theme-color" content="#FFEEEE" />
		<title>{pageTitle ? `godmothersfire ― ${pageTitle}` : "godmothersfire"}</title>
		<ClientRouter />
	</head>
	<body>
		<div class="to-background-light from-background-dark fixed top-0 left-0 -z-10 h-screen w-screen bg-radial"></div>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
