---
import { Image } from "astro:assets";
import LandingLink from "../components/LandingLink.astro";
import Document from "../components/Document.astro";
import FullBody from "../assets/fullbody.png";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const ROLES = ["Roblox Game Developer", "Full-Stack Engineer", "Graphic Designer"];
---

<Document>
	<main class="flex min-h-full w-full flex-col items-center gap-12 p-4 text-center text-balance">
		<Header isHome />
		<div class="grid w-full max-w-6xl gap-8 sm:grid-cols-4">
			<LandingLink letter="F" subtitle="Works" url="/works" />
			<LandingLink letter="I" subtitle="About" url="/about" />
			<LandingLink letter="R" subtitle="Blog" url="/blog" />
			<LandingLink letter="E" subtitle="Links" url="/links" />
		</div>
		<p class="-mb-10">{ROLES.join(" ⋅ ")}</p>
		<Footer />
	</main>
</Document>
